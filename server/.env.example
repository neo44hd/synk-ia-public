# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── CORS (separar por comas si hay varios orígenes) ───────────────────────────
CORS_ORIGINS=https://sinkialabs.com,http://localhost:5173

# ── Ollama (LLM local) ───────────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:latest
# Modelos por servicio (opcionales, caen a OLLAMA_MODEL si no se definen):
OLLAMA_CHAT_MODEL=qwen3.5
OLLAMA_CLASSIFY_MODEL=codegemma:7b

# ── Aider (Claude Code) ───────────────────────────────────────────────
AIDER_MODEL=ollama/qwen2.5-coder:14b
AIDER_PROJECT_DIR=/path/to/your/project

# ── Claude Code (proxy Anthropic → Ollama) ──────────────────────────────────
# El proxy /claude traduce API Anthropic → OpenAI para usar Claude Code original con Ollama
LOCAL_LLM_URL=http://localhost:11434
LOCAL_LLM_MODEL=qwen2.5-coder:14b

# ── SearXNG (búsqueda web) ───────────────────────────────────────────────────
SEARXNG_URL=http://localhost:8888

# ── Email / Gmail IMAP ────────────────────────────────────────────────────────
EMAIL_USER=your-email@example.com
EMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── Revo POS ──────────────────────────────────────────────────────────────────
REVO_TOKEN_LARGO=tu_token_largo_de_revo
REVO_TOKEN_CORTO=tu_token_corto_de_revo

# ── Biloop ────────────────────────────────────────────────────────────────────
BILOOP_CIF=tu_cif
ASSEMPSA_BILOOP_API_KEY=tu_api_key_biloop

# ── ESEECloud ─────────────────────────────────────────────────────────────────
ESEECLOUD_USERNAME=tu_usuario
